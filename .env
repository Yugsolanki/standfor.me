APP_ENV=development

# Server
SERVER_HOST=localhost
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=15s
SERVER_SHUTDOWN_TIMEOUT=30s

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgrestest
DATABASE_DBNAME=standfor_dev
DATABASE_SSLMODE=disable
DATABASE_MAX_OPEN_CONNS=10
DATABASE_MAX_IDLE_CONNS=5
DATABASE_MAX_CONN_LIFETIME=5m
DATABASE_MAX_CONN_IDLE_TIME=1m
DATABASE_HEALTH_CHECK_INTERVAL=30s

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=redispassword
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_POOL_SIZE=10

# JWT
JWT_SECRET=dev-secret-change-in-production-min-32-chars
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h
JWT_ISSUER=standfor.me

# Rate Limiting
RATE_LIMIT_GLOBAL_LIMIT=100
RATE_LIMIT_GLOBAL_WINDOW=1m

# PGADMIN Configuration
PGADMIN_EMAIL=admin@standfor.com
PGADMIN_PASSWORD=admin